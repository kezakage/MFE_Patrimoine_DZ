# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL + PostGIS)
POSTGRES_DB=patrimoinehub
POSTGRES_USER=patrimoine
POSTGRES_PASSWORD=patrimoine
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_ACCESS_LIFETIME_MIN=60
JWT_REFRESH_LIFETIME_DAYS=14

# MinIO / S3
USE_S3=1
AWS_ACCESS_KEY_ID=patrimoine
AWS_SECRET_ACCESS_KEY=patrimoine123
AWS_STORAGE_BUCKET_NAME=patrimoinehub-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ADDRESSING_STYLE=path

# Media upload limits (bytes)
MAX_IMAGE_SIZE=52428800
MAX_VIDEO_SIZE=524288000
